---
import Layout from '../../../layouts/Layout.astro'
import Header from '../../../components/layout/Header.astro'
import Footer from '../../../components/layout/Footer.astro'
import { TestPage } from '../../../components/test/TestPage'

const n = Number(Astro.url.searchParams.get('n') || '20')
const withTimer = Astro.url.searchParams.get('t') !== '0'
---

<Layout title="Test Aleatori - PER Quiz">
  <Header />
  <main>
    <TestPage
      client:only="react"
      modo="aleatori"
      numPreguntas={n}
      withTimer={withTimer}
    />
  </main>
  <Footer />
</Layout>
